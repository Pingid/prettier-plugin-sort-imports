{
  "name": "@pingid/prettier-plugin-sort-imports",
  "version": "0.0.13",
  "description": "A tiny Prettier plugin that keeps your import statements tidy.",
  "author": "Dan Beaven <dm.beaven@gmail.com>",
  "homepage": "https://github.com/Pingid/prettier-plugin-sort-imports#readme",
  "bugs": {
    "url": "https://github.com/Pingid/prettier-plugin-sort-imports/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pingid/prettier-plugin-sort-imports.git"
  },
  "keywords": [
    "prettier",
    "prettier-plugin",
    "imports",
    "sort",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./sort": {
      "types": "./dist/sort.d.ts",
      "import": "./dist/sort.mjs",
      "require": "./dist/sort.cjs"
    }
  },
  "scripts": {
    "build": "tsc && unbuild",
    "format": "prettier --write .",
    "test": "node --experimental-strip-types tests/run.test.ts",
    "bench": "node --experimental-strip-types bench/run.ts",
    "bench:update": "npm run build && node --experimental-strip-types bench/run.ts --update"
  },
  "peerDependencies": {
    "prettier": "^3"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "tinybench": "^4.0.1",
    "typescript": "^5.8.3",
    "prettier": "^3.5.3",
    "unbuild": "^3.5.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all"
  }
}
